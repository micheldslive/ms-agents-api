#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Git pre-push hook — runs the full test suite before every push.
# If any test fails, the push is aborted.
#
# Install: make install_hooks   (or: bash scripts/install_hooks.sh)
# Bypass:  git push --no-verify  (not recommended)
# ─────────────────────────────────────────────────────────────────────────────

set -e

echo ""
echo "🔍  Running tests before push…"
echo "    (to skip: git push --no-verify)"
echo ""

# Run the test suite via make so we get the exact same command as CI
if ! make test; then
    echo ""
    echo "❌  Tests FAILED — push aborted."
    echo "    Fix the tests and try again."
    echo ""
    exit 1
fi

echo ""
echo "✅  All tests passed — proceeding with push."
echo ""
exit 0
